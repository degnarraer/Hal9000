# Copy to .env and customize
DEPLOYMENT_ENV=development
PORT=3000
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Bob's Memory budget
# Tune these to the model context window and how aggressively memory should compact.
MEMORY_MODEL_CONTEXT_TOKENS=4096
MEMORY_CONTEXT_TRIGGER_RATIO=0.72
MEMORY_PROMPT_RESERVE_TOKENS=1200
MEMORY_SHORT_SUMMARY_INTERVAL=6
MEMORY_MEDIUM_SUMMARY_INTERVAL=20
MEMORY_LONG_SUMMARY_INTERVAL=60
MEMORY_SHORT_MAX_WORDS=120
MEMORY_MEDIUM_MAX_WORDS=250
MEMORY_LONG_MAX_WORDS=400

# Text-to-speech
# kokoro uses a local neural voice through the Kokoro CLI for open source offline speech.
TTS_PROVIDER=kokoro
# TTS_KOKORO_BIN=kokoro
# TTS_KOKORO_ARGS=--output {out}
# TTS_KOKORO_VOICE=
# piper remains supported as a fallback provider.
# TTS_PIPER_BIN=piper
# TTS_PIPER_MODEL=C:\voices\en_US-lessac-medium.onnx
# TTS_PIPER_CONFIG=C:\voices\en_US-lessac-medium.onnx.json
# TTS_PIPER_SPEAKER=
# TTS_PIPER_LENGTH_SCALE=1.0
# TTS_TIMEOUT_MS=60000

# Speech-to-text
# The voice pipeline defaults to Faster-Whisper for higher-quality turn transcription.
VOICE_PIPELINE_STT_PROVIDER=faster-whisper
FASTER_WHISPER_MODEL=base.en
FASTER_WHISPER_DEVICE=cpu
FASTER_WHISPER_COMPUTE_TYPE=int8
FASTER_WHISPER_LANGUAGE=en
FASTER_WHISPER_TIMEOUT_MS=120000
# FASTER_WHISPER_PYTHON=python
# FASTER_WHISPER_CACHE_DIR=
# Vosk uses an offline local acoustic model. Run `npm run server:install:vosk`
# or `npm run server:install` to install the default small English model.
MIC_TRANSCRIPTION_PROVIDER=pipeline
VOSK_MODEL_PATH=stt-models/vosk-model-small-en-us-0.15

# Internet-facing security
SECURITY_ENABLED=false
SECURITY_SECURE_COOKIES=false
SECURITY_SESSION_TTL_MS=28800000
CORS_ORIGIN=
SECURITY_CONFIG_PATH=./security.config.json
APP_HOST=app.localhost
AUTH_HOST=auth.localhost
APP_SITE=http://app.localhost
AUTH_SITE=http://auth.localhost
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-before-production
KEYCLOAK_DB_PASSWORD=change-me-before-production

# Keycloak / generic OIDC
# Local Keycloak quick defaults:
# - Realm: ollama-agent
# - Client ID: ollama-agent
# - Docker redirect URI: http://app.localhost/auth/callback
# - Enable user registration in the realm if you want Create account to work.
OIDC_ISSUER=http://auth.localhost/realms/ollama-agent
OIDC_CLIENT_ID=ollama-agent
OIDC_CLIENT_SECRET=change-me-before-production
OIDC_REDIRECT_URI=http://app.localhost/auth/callback
OIDC_REGISTRATION_ENDPOINT=

# Production example:
# DEPLOYMENT_ENV=production
# APP_HOST=your-app.example.com
# AUTH_HOST=auth.example.com
# APP_SITE=https://your-app.example.com
# AUTH_SITE=https://auth.example.com
# SECURITY_ENABLED=true
# SECURITY_SECURE_COOKIES=true
# OIDC_ISSUER=https://auth.example.com/realms/ollama-agent
# OIDC_REDIRECT_URI=https://your-app.example.com/auth/callback
# OIDC_CLIENT_SECRET=<generated strong secret>
# KEYCLOAK_ADMIN_PASSWORD=<generated strong secret>
# KEYCLOAK_DB_PASSWORD=<generated strong secret>

# Optional user and group allowlists live in security.config.json.

# Optional first-admin bootstrap.
# Before any admin exists, a matching signed-in user or token can promote the first administrator.
ADMIN_BOOTSTRAP_USERS=
ADMIN_BOOTSTRAP_TOKEN=
