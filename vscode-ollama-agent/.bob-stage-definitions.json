{
  "version": "1.0",
  "stages": {
    "router": {
      "title": "Router Stage",
      "inputTemplate": {
        "request": {
          "requestId": "[REQUEST ID]",
          "timestamp": "[REQUEST TIMESTAMP]",
          "sessionId": "[SESSION ID]",
          "userId": "[USER ID]"
        },
        "input": { "text": "[CHAT INPUT]", "language": "english" },
        "user": { "name": "[USER NAME]", "factoids": [[FACTOIDS]] },
        "memory": {
          "shortTerm": "[SHORT TERM MEMORY]",
          "mediumTerm": "[MEDIUM TERM MEMORY]",
          "longTerm": "[LONG TERM MEMORY]",
          "recentMessages": [[CHAT MEMORY]]
        },
        "skills": {
          "available": [[AVAILABLE SKILLS]]
        }
      },
      "outputTemplate": {
        "skill": null,
        "query": null,
        "reason": null,
        "parameters": {},
        "factoids": [
          {
            "factKey": "short-stable-key",
            "category": "preference|project|identity|environment|workflow|constraint|general",
            "fact": "The user ...",
            "confidence": 0
          }
        ]
      },
      "instructions": [
        "Read the inputTemplate.",
        "Extract durable user factoids from input.text only, before any selected skill runs.",
        "Do not use web results, assistant responses, or tool output as factoid evidence.",
        "Select exactly one skill from skills.available.",
        "Populate the outputTemplate.",
        "Return only the outputTemplate as valid JSON.",
        "Do not invent skill names."
      ]
    }
  }
}
