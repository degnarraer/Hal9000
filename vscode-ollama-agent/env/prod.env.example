DEPLOYMENT_ENV=production

APP_HOST=bobassist.duckdns.org
AUTH_HOST=bobassist-auth.duckdns.org
VAULT_HOST=bobassist-vault.duckdns.org
APP_SITE=https://bobassist.duckdns.org
AUTH_SITE=https://bobassist-auth.duckdns.org
VAULT_SITE=https://bobassist-vault.duckdns.org
HTTP_PORT=80
HTTPS_PORT=443

OLLAMA_MODEL=llama2

TTS_PROVIDER=kokoro
TTS_KOKORO_BIN=kokoro
TTS_KOKORO_ARGS=--output {out}
TTS_PIPER_BIN=/opt/piper/piper
TTS_PIPER_VOICE_DIR=./voices
TTS_PIPER_MODEL=/voices/en_US-lessac-medium.onnx
TTS_PIPER_CONFIG=/voices/en_US-lessac-medium.onnx.json
TTS_PIPER_SPEAKER=
TTS_PIPER_LENGTH_SCALE=1.0
TTS_PIPER_NOISE_SCALE=
TTS_PIPER_NOISE_W=

MIC_TRANSCRIPTION_PROVIDER=pipeline
VOICE_PIPELINE_STT_PROVIDER=faster-whisper
FASTER_WHISPER_MODEL=base.en
FASTER_WHISPER_DEVICE=cpu
FASTER_WHISPER_COMPUTE_TYPE=int8
FASTER_WHISPER_LANGUAGE=en
FASTER_WHISPER_CACHE_DIR=/data/faster-whisper
FASTER_WHISPER_TIMEOUT_MS=120000
VOSK_MODEL_DIR=./stt-models
VOSK_MODEL_PATH=/stt-models/vosk-model-small-en-us-0.15

SECURITY_SECURE_COOKIES=true
OIDC_ISSUER=https://bobassist-auth.duckdns.org/realms/ollama-agent
OIDC_CLIENT_ID=ollama-agent
OIDC_CLIENT_SECRET=replace-with-generated-secret
USER_KEY_SECRET=replace-with-generated-secret
OIDC_REDIRECT_URI=https://bobassist.duckdns.org/auth/callback
OIDC_REGISTRATION_ENDPOINT=

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=replace-with-generated-secret
KEYCLOAK_DB_PASSWORD=replace-with-generated-secret

MEMORY_ENABLED=true
MEMORY_HISTORY_LIMIT=12
MEMORY_DB_PASSWORD=replace-with-generated-secret
MEMORY_MODEL_CONTEXT_TOKENS=4096
MEMORY_CONTEXT_TRIGGER_RATIO=0.72
MEMORY_PROMPT_RESERVE_TOKENS=1200
MEMORY_SHORT_SUMMARY_INTERVAL=6
MEMORY_MEDIUM_SUMMARY_INTERVAL=20
MEMORY_LONG_SUMMARY_INTERVAL=60
MEMORY_SHORT_MAX_WORDS=120
MEMORY_MEDIUM_MAX_WORDS=250
MEMORY_LONG_MAX_WORDS=400

YAHOO_ENABLED=true
YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET=replace-with-rotated-yahoo-secret
YAHOO_REDIRECT_URI=https://bobassist.duckdns.org/api/yahoo/oauth/callback
YAHOO_OAUTH_SCOPE=openid email
YAHOO_TOKEN_ENCRYPTION_KEY=replace-with-generated-32-byte-or-longer-secret

ADMIN_BOOTSTRAP_USERS=admin@example.com
ADMIN_BOOTSTRAP_TOKEN=replace-with-generated-secret

VAULTWARDEN_ADMIN_TOKEN=replace-with-generated-secret
VAULTWARDEN_SIGNUPS_ALLOWED=false
VAULTWARDEN_INVITATIONS_ALLOWED=true
VAULTWARDEN_SSO_ENABLED=true
VAULTWARDEN_SSO_ONLY=false
VAULTWARDEN_SSO_AUTHORITY=https://bobassist-auth.duckdns.org/realms/ollama-agent
VAULTWARDEN_SSO_SCOPES=openid profile email offline_access
VAULTWARDEN_SSO_CLIENT_ID=vaultwarden
VAULTWARDEN_SSO_CLIENT_SECRET=replace-with-generated-secret
VAULTWARDEN_SSO_SIGNUPS_MATCH_EMAIL=true

# Optional encrypted Google Drive backups. Configure rclone with a remote
# such as "gdrive" first, then keep these values private in env/prod.env.
BACKUP_DIR=backups
BACKUP_RCLONE_REMOTE=gdrive:hal9000-backups
BACKUP_AGE_RECIPIENT=

# Optional DuckDNS updater container.
# Use DuckDNS names without ".duckdns.org", separated by commas.
DUCKDNS_DOMAINS=bobassist,bobassist-auth,bobassist-vault
DUCKDNS_TOKEN=
