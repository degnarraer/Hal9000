DEPLOYMENT_ENV=production

APP_HOST=your-app.example.com
AUTH_HOST=auth.example.com
HTTP_PORT=80
HTTPS_PORT=443

OLLAMA_MODEL=llama2

SECURITY_SECURE_COOKIES=true
OIDC_ISSUER=https://auth.example.com/realms/ollama-agent
OIDC_CLIENT_ID=ollama-agent
OIDC_CLIENT_SECRET=replace-with-generated-secret
OIDC_REDIRECT_URI=https://your-app.example.com/auth/callback
OIDC_REGISTRATION_ENDPOINT=

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=replace-with-generated-secret
KEYCLOAK_DB_PASSWORD=replace-with-generated-secret
