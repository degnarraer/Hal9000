DEPLOYMENT_ENV=development

APP_HOST=app.localhost
AUTH_HOST=auth.localhost
APP_SITE=http://app.localhost
AUTH_SITE=http://auth.localhost
HTTP_PORT=80
HTTPS_PORT=443

OLLAMA_MODEL=llama2

SECURITY_SECURE_COOKIES=false
OIDC_ISSUER=http://auth.localhost/realms/ollama-agent
OIDC_CLIENT_ID=ollama-agent
OIDC_CLIENT_SECRET=change-me-before-production
OIDC_REDIRECT_URI=http://app.localhost/auth/callback
OIDC_REGISTRATION_ENDPOINT=

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-before-production
KEYCLOAK_DB_PASSWORD=change-me-before-production

MEMORY_ENABLED=true
MEMORY_HISTORY_LIMIT=12
MEMORY_DB_PASSWORD=change-me-before-production
MEMORY_MODEL_CONTEXT_TOKENS=4096
MEMORY_CONTEXT_TRIGGER_RATIO=0.72
MEMORY_PROMPT_RESERVE_TOKENS=1200
MEMORY_SHORT_SUMMARY_INTERVAL=6
MEMORY_MEDIUM_SUMMARY_INTERVAL=20
MEMORY_LONG_SUMMARY_INTERVAL=60
MEMORY_SHORT_MAX_WORDS=120
MEMORY_MEDIUM_MAX_WORDS=250
MEMORY_LONG_MAX_WORDS=400

YAHOO_ENABLED=true
YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET=
YAHOO_REDIRECT_URI=http://app.localhost/api/yahoo/oauth/callback
YAHOO_OAUTH_SCOPE=openid email
YAHOO_TOKEN_ENCRYPTION_KEY=change-me-before-production

ADMIN_BOOTSTRAP_USERS=
ADMIN_BOOTSTRAP_TOKEN=
