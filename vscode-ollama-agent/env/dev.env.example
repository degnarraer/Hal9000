DEPLOYMENT_ENV=development

APP_HOST=app.localhost
AUTH_HOST=auth.localhost
HTTP_PORT=80
HTTPS_PORT=443

OLLAMA_MODEL=llama2

SECURITY_SECURE_COOKIES=false
OIDC_ISSUER=http://auth.localhost/realms/ollama-agent
OIDC_CLIENT_ID=ollama-agent
OIDC_CLIENT_SECRET=change-me-before-production
OIDC_REDIRECT_URI=http://app.localhost/auth/callback
OIDC_REGISTRATION_ENDPOINT=

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-before-production
KEYCLOAK_DB_PASSWORD=change-me-before-production
