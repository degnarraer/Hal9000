{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Local Dev / Start Server",
      "type": "shell",
      "command": "npm.cmd run start-server",
      "isBackground": true,
      "problemMatcher": [
        {
          "owner": "server",
          "pattern": {
            "regexp": "^(.*)$",
            "file": 1,
            "message": 1
          },
          "background": {
            "beginsPattern": ".",
            "endsPattern": "Server listening on"
          }
        }
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Local Dev / Stop Server",
      "type": "shell",
      "command": "npm.cmd run stop-server",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Local Dev / Open Browser",
      "type": "shell",
      "command": "Start-Process http://localhost:3000",
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "Public Website / Redeploy Everything",
      "type": "shell",
      "command": "npm.cmd run public-site:redeploy",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Public Website / Fix DuckDNS URL Update",
      "type": "shell",
      "command": "npm.cmd run public-site:fix-duckdns",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Public Website / Flush DNS Cache",
      "type": "shell",
      "command": "npm.cmd run public-site:flush-dns",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Public Website / Check URL and Ports",
      "type": "shell",
      "command": "npm.cmd run public-site:check",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Public Website / Watch Logs",
      "type": "shell",
      "command": "npm.cmd run public-site:logs",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Secrets / Vaultwarden Secrets",
      "type": "shell",
      "command": "npm.cmd run secrets:vault",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
